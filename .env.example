PORT=3000
DB_URL="host=localhost port=5432 dbname=developdb01 sslmode=disable"
SECRET=secret-key-for-jwt-authentication

# Firebase Cloud Messaging (push notifications)
# Path to the Firebase Admin SDK service account JSON file.
# Leave blank to fall back to Application Default Credentials.
FIREBASE_SERVICE_ACCOUNT_FILE=/path/to/firebase-service-account.json
# Set to "true" when sending iOS notifications to development/TestFlight builds,
# "false" (or unset) for production App Store builds.
APNS_USE_SANDBOX=true

# Resend (transactional email: password reset, etc.)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=PrayerLoop <noreply@yourdomain.com>
