PORT=3000
DB_URL="host=localhost port=5432 dbname=developdb01 sslmode=disable"
SECRET=secret-key-for-jwt-authentication

# Firebase Cloud Messaging (push notifications)
# Path to the Firebase Admin SDK service account JSON file.
# Leave blank to fall back to Application Default Credentials.
FIREBASE_SERVICE_ACCOUNT_FILE=/path/to/firebase-service-account.json
# Set to "true" when sending iOS notifications to development/TestFlight builds,
# "false" (or unset) for production App Store builds.
APNS_USE_SANDBOX=true

# Resend (transactional email: password reset, etc.)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=PrayerLoop <noreply@yourdomain.com>

# Planning Center OAuth (backend-mediated token exchange — planning doc §D/§G)
# Register at https://api.planningcenteronline.com/oauth/applications
PC_CLIENT_ID=your_planning_center_client_id
PC_CLIENT_SECRET=your_planning_center_client_secret
# AES-256-GCM key (base64, 32 bytes) for encrypting provider tokens at rest.
# Generate a separate key per environment, e.g.: openssl rand -base64 32
OAUTH_TOKEN_ENC_KEY=your_base64_32_byte_key

# Prayerloop server-side refresh token lifetime (days). Defaults to 90 if unset.
REFRESH_TOKEN_TTL_DAYS=90

# Google OAuth (Sign in with Google — planning doc §M.3/§F.6)
# Register at https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret

# Apple OAuth (Sign in with Apple — planning doc §M.3/§F.6)
# Register at https://developer.apple.com/account/resources/identifiers/list/serviceId
APPLE_CLIENT_ID=your_apple_services_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
# .p8 private key content (PEM), e.g. the output of `cat AuthKey_XXXXXXXXXX.p8`.
# Used to sign a short-lived client_secret JWT per request — not a static secret.
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# Comma-separated app bundle IDs, in addition to APPLE_CLIENT_ID, accepted as
# an id_token's audience. Native Sign in with Apple (expo-apple-authentication)
# audiences the id_token to the app's bundle ID, not the Services ID above.
APPLE_BUNDLE_IDS=com.example.app,com.example.app.dev
